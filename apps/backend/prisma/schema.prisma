generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

enum UserLocale {
  uk
  en
  ru
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique @db.Citext
  username        String   @unique @db.VarChar(32)
  passwordHash    String   @map("password_hash")
  fullName        String   @map("full_name")
  phone           String?
  avatarUrl       String?  @map("avatar_url")
  locale          UserLocale @default(uk)
  lastSeenAt      DateTime @default(now()) @map("last_seen_at") @db.Timestamptz()

  // Розширений профіль (поки без UI редагування — закладено під Блок 9)
  bio             String?  @db.Text
  city            String?  @db.VarChar(100)
  birthDate       DateTime? @map("birth_date") @db.Date
  gender          Gender?
  hobbies         String[] @default([])
  hobbiesCustom   String?  @map("hobbies_custom") @db.VarChar(200)

  // Контакти
  telegram        String?  @db.VarChar(64)
  whatsapp        String?  @db.VarChar(32)
  instagram       String?  @db.VarChar(64)
  facebook        String?  @db.VarChar(64)

  // Приватність контактних полів (за замовчуванням — приховано)
  emailVisibility     FieldVisibility @default(hidden) @map("email_visibility")
  phoneVisibility     FieldVisibility @default(hidden) @map("phone_visibility")
  telegramVisibility  FieldVisibility @default(hidden) @map("telegram_visibility")
  whatsappVisibility  FieldVisibility @default(hidden) @map("whatsapp_visibility")
  instagramVisibility FieldVisibility @default(hidden) @map("instagram_visibility")
  facebookVisibility  FieldVisibility @default(hidden) @map("facebook_visibility")

  // Налаштування приватності запрошень (для Блоку 11)
  inviteFrom      InvitePolicy @default(all) @map("invite_from")

  // Технічне
  usernameChangedAt DateTime? @map("username_changed_at") @db.Timestamptz()

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Зв'язки
  refreshTokens   RefreshToken[]
  ownedRooms      Room[]          @relation("OwnedRooms")
  memberships     RoomMember[]
  messages        Message[]
  votes           PollVote[]
  assignedItems   PollOption[]    @relation("AssignedOptions")
  createdPolls    Poll[]
  eventMemories   EventMemory[]
  aiInteractions  AiInteraction[]
  contactsOwned   Contact[]       @relation("ContactsOwned")
  contactsOf      Contact[]       @relation("ContactsOf")
  invitesSent     RoomInvite[]    @relation("InvitesSent")
  invitesReceived RoomInvite[]    @relation("InvitesReceived")
  notifications   Notification[]

  @@map("users")
}

enum Gender {
  male
  female
  unspecified
}

enum FieldVisibility {
  public      // бачать усі
  contacts    // тільки ті, кого я додав у контакти
  hidden      // не показується взагалі (навіть заголовок)
}

enum InvitePolicy {
  all         // всі можуть запрошувати
  contacts    // тільки контакти
  none        // ніхто
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  userAgent String?   @map("user_agent")
  ip        String?   @db.Inet
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum MemberRole {
  admin
  member
}

enum RoomStatus {
  active
  closed
}

model Room {
  id               String      @id @default(uuid()) @db.Uuid
  name             String      @db.VarChar(120)
  description      String?
  coverUrl         String?     @map("cover_url")
  ownerId          String      @map("owner_id") @db.Uuid
  inviteCode       String      @unique @map("invite_code") @db.VarChar(12)
  inviteToken      String      @unique @default(uuid()) @map("invite_token") @db.Uuid
  startsAt         DateTime?   @map("starts_at") @db.Date
  endsAt           DateTime?   @map("ends_at") @db.Date
  eventDate        DateTime?   @map("event_date") @db.Date
  status           RoomStatus  @default(active)
  lastActivityAt   DateTime    @default(now()) @map("last_activity_at") @db.Timestamptz()
  deletionWarnedAt DateTime?   @map("deletion_warned_at") @db.Timestamptz()
  closedAt         DateTime?   @map("closed_at") @db.Timestamptz()
  archivedAt       DateTime?   @map("archived_at") @db.Timestamptz()
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  owner          User            @relation("OwnedRooms", fields: [ownerId], references: [id], onDelete: Restrict)
  members        RoomMember[]
  messages       Message[]
  polls          Poll[]
  finalPlanItems FinalPlanItem[]
  invites        RoomInvite[]

  @@index([ownerId])
  @@index([inviteCode])
  @@index([status, lastActivityAt])
  @@index([status, eventDate])
  @@map("rooms")
}

model RoomMember {
  id         String     @id @default(uuid()) @db.Uuid
  roomId     String     @map("room_id") @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  role       MemberRole @default(member)
  joinedAt   DateTime   @default(now()) @map("joined_at") @db.Timestamptz()
  lastSeenAt DateTime?  @map("last_seen_at") @db.Timestamptz()

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("room_members")
}

enum MessageType {
  text
  system
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  roomId    String      @map("room_id") @db.Uuid
  authorId  String?     @map("author_id") @db.Uuid
  type      MessageType @default(text)
  content   String      @db.Text
  editedAt  DateTime?   @map("edited_at") @db.Timestamptz()
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  room   Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt(sort: Desc)])
  @@map("messages")
}

enum PollType {
  single_choice
  multi_choice
  location
}

enum PollStatus {
  open
  closed
  reopened
  approved
}

model Poll {
  id          String     @id @default(uuid()) @db.Uuid
  roomId      String     @map("room_id") @db.Uuid
  authorId    String     @map("author_id") @db.Uuid
  type        PollType
  title       String     @db.VarChar(200)
  description String?
  status      PollStatus @default(open)
  deadlineAt  DateTime?  @map("deadline_at") @db.Timestamptz()
  allowAssign Boolean    @default(false) @map("allow_assign")
  closedAt    DateTime?  @map("closed_at") @db.Timestamptz()
  approvedAt  DateTime?  @map("approved_at") @db.Timestamptz()
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  room    Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author  User         @relation(fields: [authorId], references: [id], onDelete: Restrict)
  options PollOption[]
  votes   PollVote[]

  @@index([roomId, status])
  @@map("polls")
}

model PollOption {
  id         String   @id @default(uuid()) @db.Uuid
  pollId     String   @map("poll_id") @db.Uuid
  label      String   @db.VarChar(255)
  position   Int      @default(0)
  latitude   Decimal? @db.Decimal(9, 6)
  longitude  Decimal? @db.Decimal(9, 6)
  address    String?
  assignedTo String?  @map("assigned_to") @db.Uuid
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  assignee User?      @relation("AssignedOptions", fields: [assignedTo], references: [id], onDelete: SetNull)
  votes    PollVote[]

  @@index([pollId])
  @@index([assignedTo])
  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(uuid()) @db.Uuid
  pollId    String   @map("poll_id") @db.Uuid
  optionId  String   @map("option_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

model FinalPlanItem {
  id         String   @id @default(uuid()) @db.Uuid
  roomId     String   @map("room_id") @db.Uuid
  pollId     String?  @map("poll_id") @db.Uuid
  optionId   String?  @map("option_id") @db.Uuid
  title      String   @db.VarChar(255)
  category   String?  @db.VarChar(50)
  latitude   Decimal? @db.Decimal(9, 6)
  longitude  Decimal? @db.Decimal(9, 6)
  address    String?
  assignedTo String?  @map("assigned_to") @db.Uuid
  payload    Json     @default("{}")
  approvedBy String   @map("approved_by") @db.Uuid
  approvedAt DateTime @default(now()) @map("approved_at") @db.Timestamptz()

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("final_plan_items")
}

model EventMemory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  roomName     String   @map("room_name") @db.VarChar(120)
  eventDate    DateTime? @map("event_date") @db.Date
  participants Json     @default("[]")
  summary      String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("event_memories")
}

model AiInteraction {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  roomId     String?    @map("room_id") @db.Uuid
  kind       String     @db.VarChar(40)
  locale     UserLocale
  prompt     String
  response   Json
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([kind])
  @@map("ai_interactions")
}

model Contact {
  id         String   @id @default(uuid()) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  contactId  String   @map("contact_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  owner   User @relation("ContactsOwned", fields: [ownerId], references: [id], onDelete: Cascade)
  contact User @relation("ContactsOf", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactId])
  @@index([ownerId])
  @@index([contactId])
  @@map("contacts")
}

enum InviteStatus {
  pending     // чекає рішення одержувача
  accepted    // прийнято, юзер у кімнаті
  declined    // відхилено (запис лишається для запрошувача)
  deferred    // "Пізніше" — лишається в сповіщеннях
  cancelled   // запрошувач скасував
}

model RoomInvite {
  id            String       @id @default(uuid()) @db.Uuid
  roomId        String       @map("room_id") @db.Uuid
  invitedById   String       @map("invited_by_id") @db.Uuid
  invitedUserId String       @map("invited_user_id") @db.Uuid
  status        InviteStatus @default(pending)
  message       String?      @db.VarChar(500)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  respondedAt   DateTime?    @map("responded_at") @db.Timestamptz()

  room        Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUser User @relation("InvitesReceived", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([roomId, invitedUserId, status])
  @@index([invitedUserId, status])
  @@index([roomId])
  @@map("room_invites")
}

enum NotificationKind {
  room_invite
  room_invite_accepted
  room_invite_declined
  member_removed
  room_admin_transferred
  room_deletion_warning
  system
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  kind      NotificationKind
  payload   Json             @default("{}")
  readAt    DateTime?        @map("read_at") @db.Timestamptz()
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}