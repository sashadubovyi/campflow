# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL) — добавим в следующем спринте
DATABASE_URL=postgresql://campflow:campflow@localhost:5432/campflow?schema=public

# Redis — добавим в следующем спринте
REDIS_URL=redis://localhost:6379

# JWT — заполним позже
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Gemini — заполним когда дойдём до AI-спринта
GEMINI_API_KEY=