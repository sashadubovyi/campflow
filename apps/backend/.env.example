# ─── База даних ────────────────────────────────────────────────────────────
# Postgres connection string. Railway / Supabase / локальний — без різниці.
DATABASE_URL=postgresql://campflow:campflow@localhost:5432/campflow?schema=public

# ─── Сервер ────────────────────────────────────────────────────────────────
# Порт. Railway автоматично виставляє PORT — слухати треба саме його.
PORT=3001
NODE_ENV=development

# ─── CORS / Frontend ───────────────────────────────────────────────────────
# Origin фронта; cookie-based refresh-токен ходить лише з цього домена.
FRONTEND_URL=http://localhost:5173

# ─── JWT ───────────────────────────────────────────────────────────────────
# Згенеруй довгу випадкову строку: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
# Час життя access-токена (короткий, бо refresh є)
JWT_ACCESS_TTL=15m
# Час життя refresh-токена в днях (число або 'Xd')
JWT_REFRESH_TTL=7d

# ─── Gemini (AI) ───────────────────────────────────────────────────────────
# Ключ AI Studio (https://aistudio.google.com/app/apikey). Опціональний:
# якщо відсутній — AI-фічі (драфт кімнат, AI-плани) повертатимуть
# ServiceUnavailable, але інше працює.
GEMINI_API_KEY=

# ─── OAuth ────────────────────────────────────────────────────────────────
# Google Sign-In (https://console.cloud.google.com → OAuth 2.0 Client IDs →
# Web). Той самий client ID треба передати на фронт як VITE_GOOGLE_CLIENT_ID.
GOOGLE_OAUTH_CLIENT_ID=

# Apple Sign-In Service ID (developer.apple.com → Certificates, Identifiers
# & Profiles → Services ID, з увімкненим Sign In with Apple). Той самий
# service ID іде на фронт як VITE_APPLE_CLIENT_ID.
APPLE_OAUTH_CLIENT_ID=

# Facebook Login (developers.facebook.com → My Apps → Settings → Basic).
# App ID видно публічно, App Secret — ні. App Secret потрібен бекенду для
# валідації токена через debug_token + appsecret_proof.
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
