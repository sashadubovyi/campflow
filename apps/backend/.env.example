# ─── База даних ────────────────────────────────────────────────────────────
# Postgres connection string. Railway / Supabase / локальний — без різниці.
DATABASE_URL=postgresql://campflow:campflow@localhost:5432/campflow?schema=public

# ─── Сервер ────────────────────────────────────────────────────────────────
# Порт. Railway автоматично виставляє PORT — слухати треба саме його.
PORT=3001
NODE_ENV=development

# ─── CORS / Frontend ───────────────────────────────────────────────────────
# Origin фронта; cookie-based refresh-токен ходить лише з цього домена.
FRONTEND_URL=http://localhost:5173

# ─── JWT ───────────────────────────────────────────────────────────────────
# Згенеруй довгу випадкову строку: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
# Час життя access-токена (короткий, бо refresh є)
JWT_ACCESS_TTL=15m
# Час життя refresh-токена в днях (число або 'Xd')
JWT_REFRESH_TTL=7d

# ─── Gemini (AI) ───────────────────────────────────────────────────────────
# Ключ AI Studio (https://aistudio.google.com/app/apikey). Опціональний:
# якщо відсутній — AI-фічі (драфт кімнат, AI-плани) повертатимуть
# ServiceUnavailable, але інше працює.
GEMINI_API_KEY=
