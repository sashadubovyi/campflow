# Origin бекенду без хвостового слешу. У dev лишай порожнім — Vite-проксі
# у vite.config.ts проксює /api, /uploads і /socket.io на http://localhost:3001.
# Для prod — це домен Railway-сервісу, напр. https://andu-backend.up.railway.app
VITE_API_URL=

# ── OAuth ───────────────────────────────────────────────────────────────
# Той самий ID, що задано на бекенді як GOOGLE_OAUTH_CLIENT_ID.
# Якщо порожній — Google-кнопка не з'явиться (звичайний email-логін
# продовжить працювати).
VITE_GOOGLE_CLIENT_ID=

# Apple Services ID (НЕ Bundle ID; той самий що APPLE_OAUTH_CLIENT_ID
# на бекенді). VITE_APPLE_REDIRECT_URI має точно збігатись із Return URL
# у налаштуваннях Apple Services ID.
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=

# Facebook App ID (видно публічно, той самий що FACEBOOK_OAUTH_CLIENT_ID
# на бекенді). App Secret на фронт НЕ передаємо.
VITE_FACEBOOK_APP_ID=
