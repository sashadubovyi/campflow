From 505bfbfd4244e7b6d68701246aa443b5037b1d17 Mon Sep 17 00:00:00 2001
From: sashadubovyi <125696737+sashadubovyi@users.noreply.github.com>
Date: Sun, 7 Jun 2026 00:06:43 +0300
Subject: [PATCH 32/45] feat(frontend): add uploadAvatar API method +
 useUploadAvatar hook

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 apps/frontend/src/shared/api/profile.api.ts   |  9 +++++++++
 apps/frontend/src/shared/api/profile.hooks.ts | 12 +++++++++++-
 2 files changed, 20 insertions(+), 1 deletion(-)

diff --git a/apps/frontend/src/shared/api/profile.api.ts b/apps/frontend/src/shared/api/profile.api.ts
index aefea60..0ae4630 100644
--- a/apps/frontend/src/shared/api/profile.api.ts
+++ b/apps/frontend/src/shared/api/profile.api.ts
@@ -88,4 +88,13 @@ export const profileApi = {
     const { data } = await api.patch<MyProfile>('/users/me', payload);
     return data;
   },
+
+  async uploadAvatar(file: File): Promise<{ avatarUrl: string }> {
+    const form = new FormData();
+    form.append('avatar', file);
+    const { data } = await api.post<{ avatarUrl: string }>('/users/me/avatar', form, {
+      headers: { 'Content-Type': 'multipart/form-data' },
+    });
+    return data;
+  },
 };
diff --git a/apps/frontend/src/shared/api/profile.hooks.ts b/apps/frontend/src/shared/api/profile.hooks.ts
index 84d15ba..788d0c1 100644
--- a/apps/frontend/src/shared/api/profile.hooks.ts
+++ b/apps/frontend/src/shared/api/profile.hooks.ts
@@ -22,8 +22,18 @@ export function useUpdateMyProfile() {
     mutationFn: (payload: UpdateProfilePayload) => profileApi.updateMyProfile(payload),
     onSuccess: (data) => {
       qc.setQueryData(['myProfile'], data);
-      // інвалідуємо публічний профіль теж, щоб одразу побачити зміни на /u/:username
       qc.invalidateQueries({ queryKey: ['profile', data.username] });
     },
   });
 }
+
+export function useUploadAvatar() {
+  const qc = useQueryClient();
+  return useMutation({
+    mutationFn: (file: File) => profileApi.uploadAvatar(file),
+    onSuccess: () => {
+      qc.invalidateQueries({ queryKey: ['myProfile'] });
+      qc.invalidateQueries({ queryKey: ['profile'] });
+    },
+  });
+}
-- 
